{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "vite/client",
      "node",
      "vitest",
    ],
    "noImplicitAny": false,
    "strictPropertyInitialization": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "moduleResolution": "node",
  },
  "include": [
    "src/**/*.ts",
    "../../libs/src/**/*.ts",
    "../../generated/prisma/client.ts",
    "../../prisma/prisma.ts",
  ],
}
