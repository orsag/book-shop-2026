{
  "name": "hono-backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/hono-backend/src",
  "projectType": "application",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/hono-backend/tsconfig.app.json --noEmit"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["typecheck"],
      "inputs": ["production", "^production"],
      "outputs": ["{workspaceRoot}/dist/apps/hono-backend"],
      "options": {
        "commands": [
          "/Users/martinorsag/.bun/bin/bun build apps/hono-backend/src/main.ts --outdir dist/apps/hono-backend --target bun",
          "cp -r apps/hono-backend/src/assets dist/apps/hono-backend/assets"
        ],
        "parallel": false
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "/Users/martinorsag/.bun/bin/bun --env-file=.env --watch apps/hono-backend/src/main.ts"
      }
    }
  }
}
